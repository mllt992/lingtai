{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Loft",
  "version": "0.1.0",
  "identifier": "com.loft.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "凌台 · Loft",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      },
      {
        "label": "hud",
        "title": "Loft HUD",
        "url": "index.html?hud=1",
        "width": 360,
        "height": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "桌面控制台",
    "longDescription": "凌台 Loft — 轻量级 Windows 桌面控制台：快速启动 / 文件归纳 / 端口监控 / 性能监控"
  }
}
