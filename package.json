{
  "name": "loft",
  "private": true,
  "version": "0.1.0",
  "description": "凌台 Loft — 轻量级 Windows 桌面控制台：启动器 / 文件归纳 / 端口监控 / 性能监控",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "exe": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-exe.ps1",
    "exe:installer": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-exe.ps1 -Installer",
    "exe:open": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-exe.ps1 -Open",
    "icons": "node scripts/gen-icons.mjs",
    "postinstall": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-opener": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.10",
    "@tauri-apps/cli": "^2.1.0",
    "@unocss/preset-icons": "^0.65.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "unocss": "^0.65.4",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
